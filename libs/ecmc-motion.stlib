    {
      "fileName": "ecmc_motion.st",
      "source": "TYPE ECMC_AXIS_REF :\nSTRUCT\n  AxisIndex : DINT;\nEND_STRUCT\nEND_TYPE\n\nFUNCTION_BLOCK MC_Power\nVAR_INPUT\n  Axis   : ECMC_AXIS_REF;\n  Enable : BOOL;\nEND_VAR\nVAR_OUTPUT\n  Status  : BOOL;\n  Valid   : BOOL;\n  Busy    : BOOL;\n  Error   : BOOL;\n  ErrorID : UDINT;\n  Active  : BOOL;\nEND_VAR\nVAR\n  StatePtr : ULINT;\nEND_VAR\n{external\n  auto *handle = reinterpret_cast<ecmcMcPowerHandle *>(static_cast<uintptr_t>(STATEPTR.get()));\n  if (!handle) {\n    handle = ecmcMcPowerCreate();\n    STATEPTR.set(static_cast<ULINT_t>(reinterpret_cast<uintptr_t>(handle)));\n  }\n\n  if (!handle) {\n    STATUS.set(false);\n    VALID.set(false);\n    BUSY.set(false);\n    ERROR.set(true);\n    ERRORID.set(static_cast<UDINT_t>(0xffffffffu));\n    ACTIVE.set(false);\n  } else {\n    ecmcMcPowerStatus fb_status{};\n    ecmcMcPowerRun(handle, AXIS.AXISINDEX.get(), ENABLE.get() ? 1 : 0, &fb_status);\n    STATUS.set(fb_status.Status != 0);\n    VALID.set(fb_status.Valid != 0);\n    BUSY.set(fb_status.base.Busy != 0);\n    ERROR.set(fb_status.base.Error != 0);\n    ERRORID.set(static_cast<UDINT_t>(fb_status.base.ErrorID));\n    ACTIVE.set(fb_status.base.Active != 0);\n  }\n}\nEND_FUNCTION_BLOCK\n\nFUNCTION_BLOCK MC_Reset\nVAR_INPUT\n  Axis    : ECMC_AXIS_REF;\n  Execute : BOOL;\nEND_VAR\nVAR_OUTPUT\n  Done    : BOOL;\n  Busy    : BOOL;\n  Error   : BOOL;\n  ErrorID : UDINT;\n  Active  : BOOL;\nEND_VAR\nVAR\n  StatePtr : ULINT;\nEND_VAR\n{external\n  auto *handle = reinterpret_cast<ecmcMcResetHandle *>(static_cast<uintptr_t>(STATEPTR.get()));\n  if (!handle) {\n    handle = ecmcMcResetCreate();\n    STATEPTR.set(static_cast<ULINT_t>(reinterpret_cast<uintptr_t>(handle)));\n  }\n\n  if (!handle) {\n    DONE.set(false);\n    BUSY.set(false);\n    ERROR.set(true);\n    ERRORID.set(static_cast<UDINT_t>(0xffffffffu));\n    ACTIVE.set(false);\n  } else {\n    ecmcMcResetStatus fb_status{};\n    ecmcMcResetRun(handle, AXIS.AXISINDEX.get(), EXECUTE.get() ? 1 : 0, &fb_status);\n    DONE.set(fb_status.base.Done != 0);\n    BUSY.set(fb_status.base.Busy != 0);\n    ERROR.set(fb_status.base.Error != 0);\n    ERRORID.set(static_cast<UDINT_t>(fb_status.base.ErrorID));\n    ACTIVE.set(fb_status.base.Active != 0);\n  }\n}\nEND_FUNCTION_BLOCK\n\nFUNCTION_BLOCK MC_MoveAbsolute\nVAR_INPUT\n  Axis         : ECMC_AXIS_REF;\n  Execute      : BOOL;\n  Position     : LREAL;\n  Velocity     : LREAL;\n  Acceleration : LREAL;\n  Deceleration : LREAL;\nEND_VAR\nVAR_OUTPUT\n  Done            : BOOL;\n  Busy            : BOOL;\n  Active          : BOOL;\n  CommandAborted  : BOOL;\n  Error           : BOOL;\n  ErrorID         : UDINT;\nEND_VAR\nVAR\n  StatePtr : ULINT;\nEND_VAR\n{external\n  auto *handle = reinterpret_cast<ecmcMcMoveAbsoluteHandle *>(static_cast<uintptr_t>(STATEPTR.get()));\n  if (!handle) {\n    handle = ecmcMcMoveAbsoluteCreate();\n    STATEPTR.set(static_cast<ULINT_t>(reinterpret_cast<uintptr_t>(handle)));\n  }\n\n  if (!handle) {\n    DONE.set(false);\n    BUSY.set(false);\n    ACTIVE.set(false);\n    COMMANDABORTED.set(false);\n    ERROR.set(true);\n    ERRORID.set(static_cast<UDINT_t>(0xffffffffu));\n  } else {\n    ecmcMcMoveAbsoluteStatus fb_status{};\n    ecmcMcMoveAbsoluteRun(handle,\n                          AXIS.AXISINDEX.get(),\n                          EXECUTE.get() ? 1 : 0,\n                          POSITION.get(),\n                          VELOCITY.get(),\n                          ACCELERATION.get(),\n                          DECELERATION.get(),\n                          &fb_status);\n    DONE.set(fb_status.base.Done != 0);\n    BUSY.set(fb_status.base.Busy != 0);\n    ACTIVE.set(fb_status.base.Active != 0);\n    COMMANDABORTED.set(fb_status.base.CommandAborted != 0);\n    ERROR.set(fb_status.base.Error != 0);\n    ERRORID.set(static_cast<UDINT_t>(fb_status.base.ErrorID));\n  }\n}\nEND_FUNCTION_BLOCK\n\nFUNCTION_BLOCK MC_MoveRelative\nVAR_INPUT\n  Axis         : ECMC_AXIS_REF;\n  Execute      : BOOL;\n  Distance     : LREAL;\n  Velocity     : LREAL;\n  Acceleration : LREAL;\n  Deceleration : LREAL;\nEND_VAR\nVAR_OUTPUT\n  Done            : BOOL;\n  Busy            : BOOL;\n  Active          : BOOL;\n  CommandAborted  : BOOL;\n  Error           : BOOL;\n  ErrorID         : UDINT;\nEND_VAR\nVAR\n  StatePtr : ULINT;\nEND_VAR\n{external\n  auto *handle = reinterpret_cast<ecmcMcMoveRelativeHandle *>(static_cast<uintptr_t>(STATEPTR.get()));\n  if (!handle) {\n    handle = ecmcMcMoveRelativeCreate();\n    STATEPTR.set(static_cast<ULINT_t>(reinterpret_cast<uintptr_t>(handle)));\n  }\n\n  if (!handle) {\n    DONE.set(false);\n    BUSY.set(false);\n    ACTIVE.set(false);\n    COMMANDABORTED.set(false);\n    ERROR.set(true);\n    ERRORID.set(static_cast<UDINT_t>(0xffffffffu));\n  } else {\n    ecmcMcMoveRelativeStatus fb_status{};\n    ecmcMcMoveRelativeRun(handle,\n                          AXIS.AXISINDEX.get(),\n                          EXECUTE.get() ? 1 : 0,\n                          DISTANCE.get(),\n                          VELOCITY.get(),\n                          ACCELERATION.get(),\n                          DECELERATION.get(),\n                          &fb_status);\n    DONE.set(fb_status.base.Done != 0);\n    BUSY.set(fb_status.base.Busy != 0);\n    ACTIVE.set(fb_status.base.Active != 0);\n    COMMANDABORTED.set(fb_status.base.CommandAborted != 0);\n    ERROR.set(fb_status.base.Error != 0);\n    ERRORID.set(static_cast<UDINT_t>(fb_status.base.ErrorID));\n  }\n}\nEND_FUNCTION_BLOCK\n\nFUNCTION_BLOCK MC_MoveVelocity\nVAR_INPUT\n  Axis         : ECMC_AXIS_REF;\n  Execute      : BOOL;\n  Velocity     : LREAL;\n  Acceleration : LREAL;\n  Deceleration : LREAL;\nEND_VAR\nVAR_OUTPUT\n  InVelocity      : BOOL;\n  Busy            : BOOL;\n  Active          : BOOL;\n  CommandAborted  : BOOL;\n  Error           : BOOL;\n  ErrorID         : UDINT;\nEND_VAR\nVAR\n  StatePtr : ULINT;\nEND_VAR\n{external\n  auto *handle = reinterpret_cast<ecmcMcMoveVelocityHandle *>(static_cast<uintptr_t>(STATEPTR.get()));\n  if (!handle) {\n    handle = ecmcMcMoveVelocityCreate();\n    STATEPTR.set(static_cast<ULINT_t>(reinterpret_cast<uintptr_t>(handle)));\n  }\n\n  if (!handle) {\n    INVELOCITY.set(false);\n    BUSY.set(false);\n    ACTIVE.set(false);\n    COMMANDABORTED.set(false);\n    ERROR.set(true);\n    ERRORID.set(static_cast<UDINT_t>(0xffffffffu));\n  } else {\n    ecmcMcMoveVelocityStatus fb_status{};\n    ecmcMcMoveVelocityRun(handle,\n                          AXIS.AXISINDEX.get(),\n                          EXECUTE.get() ? 1 : 0,\n                          VELOCITY.get(),\n                          ACCELERATION.get(),\n                          DECELERATION.get(),\n                          &fb_status);\n    INVELOCITY.set(fb_status.InVelocity != 0);\n    BUSY.set(fb_status.base.Busy != 0);\n    ACTIVE.set(fb_status.base.Active != 0);\n    COMMANDABORTED.set(fb_status.base.CommandAborted != 0);\n    ERROR.set(fb_status.base.Error != 0);\n    ERRORID.set(static_cast<UDINT_t>(fb_status.base.ErrorID));\n  }\n}\nEND_FUNCTION_BLOCK\n\nFUNCTION_BLOCK MC_Home\nVAR_INPUT\n  Axis               : ECMC_AXIS_REF;\n  Execute            : BOOL;\n  SeqId              : DINT;\n  HomePosition       : LREAL;\n  VelocityTowardsCam : LREAL;\n  VelocityOffCam     : LREAL;\n  Acceleration       : LREAL;\n  Deceleration       : LREAL;\nEND_VAR\nVAR_OUTPUT\n  Done            : BOOL;\n  Busy            : BOOL;\n  Active          : BOOL;\n  CommandAborted  : BOOL;\n  Error           : BOOL;\n  ErrorID         : UDINT;\nEND_VAR\nVAR\n  StatePtr : ULINT;\nEND_VAR\n{external\n  auto *handle = reinterpret_cast<ecmcMcHomeHandle *>(static_cast<uintptr_t>(STATEPTR.get()));\n  if (!handle) {\n    handle = ecmcMcHomeCreate();\n    STATEPTR.set(static_cast<ULINT_t>(reinterpret_cast<uintptr_t>(handle)));\n  }\n\n  if (!handle) {\n    DONE.set(false);\n    BUSY.set(false);\n    ACTIVE.set(false);\n    COMMANDABORTED.set(false);\n    ERROR.set(true);\n    ERRORID.set(static_cast<UDINT_t>(0xffffffffu));\n  } else {\n    ecmcMcHomeStatus fb_status{};\n    ecmcMcHomeRun(handle,\n                  AXIS.AXISINDEX.get(),\n                  EXECUTE.get() ? 1 : 0,\n                  static_cast<int>(SEQID.get()),\n                  HOMEPOSITION.get(),\n                  VELOCITYTOWARDSCAM.get(),\n                  VELOCITYOFFCAM.get(),\n                  ACCELERATION.get(),\n                  DECELERATION.get(),\n                  &fb_status);\n    DONE.set(fb_status.base.Done != 0);\n    BUSY.set(fb_status.base.Busy != 0);\n    ACTIVE.set(fb_status.base.Active != 0);\n    COMMANDABORTED.set(fb_status.base.CommandAborted != 0);\n    ERROR.set(fb_status.base.Error != 0);\n    ERRORID.set(static_cast<UDINT_t>(fb_status.base.ErrorID));\n  }\n}\nEND_FUNCTION_BLOCK\n\nFUNCTION_BLOCK MC_Halt\nVAR_INPUT\n  Axis    : ECMC_AXIS_REF;\n  Execute : BOOL;\nEND_VAR\nVAR_OUTPUT\n  Done            : BOOL;\n  Busy            : BOOL;\n  Active          : BOOL;\n  CommandAborted  : BOOL;\n  Error           : BOOL;\n  ErrorID         : UDINT;\nEND_VAR\nVAR\n  StatePtr : ULINT;\nEND_VAR\n{external\n  auto *handle = reinterpret_cast<ecmcMcHaltHandle *>(static_cast<uintptr_t>(STATEPTR.get()));\n  if (!handle) {\n    handle = ecmcMcHaltCreate();\n    STATEPTR.set(static_cast<ULINT_t>(reinterpret_cast<uintptr_t>(handle)));\n  }\n\n  if (!handle) {\n    DONE.set(false);\n    BUSY.set(false);\n    ACTIVE.set(false);\n    COMMANDABORTED.set(false);\n    ERROR.set(true);\n    ERRORID.set(static_cast<UDINT_t>(0xffffffffu));\n  } else {\n    ecmcMcHaltStatus fb_status{};\n    ecmcMcHaltRun(handle, AXIS.AXISINDEX.get(), EXECUTE.get() ? 1 : 0, &fb_status);\n    DONE.set(fb_status.base.Done != 0);\n    BUSY.set(fb_status.base.Busy != 0);\n    ACTIVE.set(fb_status.base.Active != 0);\n    COMMANDABORTED.set(fb_status.base.CommandAborted != 0);\n    ERROR.set(fb_status.base.Error != 0);\n    ERRORID.set(static_cast<UDINT_t>(fb_status.base.ErrorID));\n  }\n}\nEND_FUNCTION_BLOCK\n\nFUNCTION_BLOCK MC_ReadStatus\nVAR_INPUT\n  Axis   : ECMC_AXIS_REF;\n  Enable : BOOL;\nEND_VAR\nVAR_OUTPUT\n  Valid              : BOOL;\n  Busy               : BOOL;\n  Error              : BOOL;\n  ErrorID            : UDINT;\n  ErrorStop          : BOOL;\n  Disabled           : BOOL;\n  Stopping           : BOOL;\n  Homing             : BOOL;\n  StandStill         : BOOL;\n  DiscreteMotion     : BOOL;\n  ContinuousMotion   : BOOL;\n  SynchronizedMotion : BOOL;\nEND_VAR\nVAR\n  StatePtr : ULINT;\nEND_VAR\n{external\n  auto *handle = reinterpret_cast<ecmcMcReadStatusHandle *>(static_cast<uintptr_t>(STATEPTR.get()));\n  if (!handle) {\n    handle = ecmcMcReadStatusCreate();\n    STATEPTR.set(static_cast<ULINT_t>(reinterpret_cast<uintptr_t>(handle)));\n  }\n\n  if (!handle) {\n    VALID.set(false);\n    BUSY.set(false);\n    ERROR.set(true);\n    ERRORID.set(static_cast<UDINT_t>(0xffffffffu));\n    ERRORSTOP.set(false);\n    DISABLED.set(false);\n    STOPPING.set(false);\n    HOMING.set(false);\n    STANDSTILL.set(false);\n    DISCRETEMOTION.set(false);\n    CONTINUOUSMOTION.set(false);\n    SYNCHRONIZEDMOTION.set(false);\n  } else {\n    ecmcMcReadStatusStatus fb_status{};\n    ecmcMcReadStatusRun(handle, AXIS.AXISINDEX.get(), ENABLE.get() ? 1 : 0, &fb_status);\n    VALID.set(fb_status.Valid != 0);\n    BUSY.set(fb_status.base.Busy != 0);\n    ERROR.set(fb_status.base.Error != 0);\n    ERRORID.set(static_cast<UDINT_t>(fb_status.base.ErrorID));\n    ERRORSTOP.set(fb_status.ErrorStop != 0);\n    DISABLED.set(fb_status.Disabled != 0);\n    STOPPING.set(fb_status.Stopping != 0);\n    HOMING.set(fb_status.Homing != 0);\n    STANDSTILL.set(fb_status.StandStill != 0);\n    DISCRETEMOTION.set(fb_status.DiscreteMotion != 0);\n    CONTINUOUSMOTION.set(fb_status.ContinuousMotion != 0);\n    SYNCHRONIZEDMOTION.set(fb_status.SynchronizedMotion != 0);\n  }\n}\nEND_FUNCTION_BLOCK\n\nFUNCTION_BLOCK MC_ReadActualPosition\nVAR_INPUT\n  Axis   : ECMC_AXIS_REF;\n  Enable : BOOL;\nEND_VAR\nVAR_OUTPUT\n  Valid    : BOOL;\n  Busy     : BOOL;\n  Error    : BOOL;\n  ErrorID  : UDINT;\n  Position : LREAL;\nEND_VAR\nVAR\n  StatePtr : ULINT;\nEND_VAR\n{external\n  auto *handle = reinterpret_cast<ecmcMcReadActualPositionHandle *>(static_cast<uintptr_t>(STATEPTR.get()));\n  if (!handle) {\n    handle = ecmcMcReadActualPositionCreate();\n    STATEPTR.set(static_cast<ULINT_t>(reinterpret_cast<uintptr_t>(handle)));\n  }\n\n  if (!handle) {\n    VALID.set(false);\n    BUSY.set(false);\n    ERROR.set(true);\n    ERRORID.set(static_cast<UDINT_t>(0xffffffffu));\n    POSITION.set(0.0);\n  } else {\n    ecmcMcReadActualPositionStatus fb_status{};\n    ecmcMcReadActualPositionRun(handle, AXIS.AXISINDEX.get(), ENABLE.get() ? 1 : 0, &fb_status);\n    VALID.set(fb_status.Valid != 0);\n    BUSY.set(fb_status.base.Busy != 0);\n    ERROR.set(fb_status.base.Error != 0);\n    ERRORID.set(static_cast<UDINT_t>(fb_status.base.ErrorID));\n    POSITION.set(fb_status.Position);\n  }\n}\nEND_FUNCTION_BLOCK\n\nFUNCTION_BLOCK MC_ReadActualVelocity\nVAR_INPUT\n  Axis   : ECMC_AXIS_REF;\n  Enable : BOOL;\nEND_VAR\nVAR_OUTPUT\n  Valid    : BOOL;\n  Busy     : BOOL;\n  Error    : BOOL;\n  ErrorID  : UDINT;\n  Velocity : LREAL;\nEND_VAR\nVAR\n  StatePtr : ULINT;\nEND_VAR\n{external\n  auto *handle = reinterpret_cast<ecmcMcReadActualVelocityHandle *>(static_cast<uintptr_t>(STATEPTR.get()));\n  if (!handle) {\n    handle = ecmcMcReadActualVelocityCreate();\n    STATEPTR.set(static_cast<ULINT_t>(reinterpret_cast<uintptr_t>(handle)));\n  }\n\n  if (!handle) {\n    VALID.set(false);\n    BUSY.set(false);\n    ERROR.set(true);\n    ERRORID.set(static_cast<UDINT_t>(0xffffffffu));\n    VELOCITY.set(0.0);\n  } else {\n    ecmcMcReadActualVelocityStatus fb_status{};\n    ecmcMcReadActualVelocityRun(handle, AXIS.AXISINDEX.get(), ENABLE.get() ? 1 : 0, &fb_status);\n    VALID.set(fb_status.Valid != 0);\n    BUSY.set(fb_status.base.Busy != 0);\n    ERROR.set(fb_status.base.Error != 0);\n    ERRORID.set(static_cast<UDINT_t>(fb_status.base.ErrorID));\n    VELOCITY.set(fb_status.Velocity);\n  }\n}\nEND_FUNCTION_BLOCK\n"
    }
  ]
}
